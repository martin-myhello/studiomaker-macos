{
  "$schema": "https://raw.githubusercontent.com/nickelpack/tauri/tauri-v2/crates/tauri-config-schema/schema.json",
  "identifier": "app.studiomaker",
  "productName": "StudioMaker",
  "version": "1.0.0",
  "build": {
    "frontendDist": "https://studiomaker.app"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "url": "https://studiomaker.app",
        "title": "StudioMaker",
        "width": 1280,
        "height": 860,
        "minWidth": 380,
        "minHeight": 380,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 7, "y": 16 },
        "backgroundColor": [255, 255, 255, 255]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "14.0"
    },
    "iOS": {
      "minimumSystemVersion": "16.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/martin-myhello/studiomaker-macos/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwRjZBMDc2NENENzg0MTAKUldRUWhOZE1kcUQyb0UxdXY3enFpN1MwOUQxM1JXaGtIWThxaGRLZ0xCeGYvOGZFbkFibGtoSDQK"
    }
  }
}

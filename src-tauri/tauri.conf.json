{
  "$schema": "https://raw.githubusercontent.com/nickelpack/tauri/tauri-v2/crates/tauri-config-schema/schema.json",
  "identifier": "io.myhello.studio",
  "productName": "Studio",
  "version": "0.2.0",
  "build": {
    "frontendDist": "https://studio.myhello.io"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "url": "https://studio.myhello.io",
        "title": "Studio",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 24 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/martin-myhello/studio-native/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
